pipeline {
    agent {
        docker {
            image 'node:18-alpine'
            args  '-v /tmp:/tmp'
        }
    }

    environment {
        NODE_ENV         = 'test'
        BUILD_DIR        = '.next'
        APP_NAME         = 'kijanikiosk-payments'
        NEXUS_URL        = 'http://localhost:8081/repository/npm-kijanikiosk/'
        
        // Dynamic environment variable evaluations
        PKG_VERSION      = sh(script: "node -p \"require('./package.json').version\"", returnStdout: true).trim()
        GIT_SHORT        = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
        ARTIFACT_VERSION = "${PKG_VERSION}-b${BUILD_NUMBER}-${GIT_SHORT}"
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {
        stage('Lint') {
            steps {
                echo "Running code linter (Fail-Fast Verification)..."
                sh 'npm run lint'
            }
        }

        stage('Build') {
            steps {
                echo "Installing dependencies via clean installation..."
                sh 'npm ci --prefer-offline --no-audit'

                echo "Building production package assets..."
                sh 'npm run build'

                echo "Verifying build output directory target..."
                sh '''
                    set -e
                    test -d "${BUILD_DIR}" || { echo "ERROR: ${BUILD_DIR} directory missing"; exit 1; }
                    test -s "${BUILD_DIR}" || { echo "ERROR: ${BUILD_DIR} directory is empty"; exit 1; }
                '''

                echo "Stashing workspace artifacts for parallel execution..."
                // Stash everything needed for subsequent steps to prevent node execution environment divergence
                stash name: 'build-assets', include: "${BUILD_DIR}/**, package.json, package-lock.json"
            }
        }

        stage('Verify') {
            parallel {
                stage('Test') {
                    steps {
                        echo "Unstashing build assets for unit testing..."
                        unstash 'build-assets'
                        
                        sh '''
                            set -e
                            npm test -- --reporter=junit --reporter-options output=test-results/junit.xml
                        '''
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'test-results/*.xml'
                        }
                    }
                }
                
                stage('Security Audit') {
                    steps {
                        echo "Running vulnerability analysis scans..."
                        // Scans package-lock.json natively; runs perfectly isolated
                        sh 'npm audit --audit-level=high'
                    }
                }
            }
        }

        stage('Archive') {
            steps {
                echo "Archiving workspace outputs to Jenkins controller master..."
                archiveArtifacts artifacts: "${BUILD_DIR}/**",
                                 fingerprint: true,
                                 onlyIfSuccessful: true
            }
        }

        stage('Publish') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-credentials',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    sh '''
                        set -e

                        # 1. Register target cleanup handlers immediately
                        trap "rm -f .npmrc" EXIT

                        # 2. Extract configuration metadata tokens
                        NEXUS_TOKEN=$(echo -n "${NEXUS_USER}:${NEXUS_PASS}" | base64)

                        # 3. Write out npm authentication profile configuration mappings
                        cat > .npmrc << NPMRC
registry=http://localhost:8081/repository/npm-kijanikiosk/
//localhost:8081/repository/npm-kijanikiosk/:_authToken=${NEXUS_TOKEN}
NPMRC

                        # 4. Bump manifest parameters to the pipeline version identifier
                        npm version "${ARTIFACT_VERSION}" --no-git-tag-version

                        # 5. Execute binary upload sequence targets
                        npm publish
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "SUCCESS: Published target ${APP_NAME} version ${ARTIFACT_VERSION} to Nexus repository cluster."
            echo "Artifact URL Location: ${NEXUS_URL}/${APP_NAME}/-/${APP_NAME}-${ARTIFACT_VERSION}.tgz"
        }
        failure {
            echo "CRITICAL: Pipeline Execution Failure found at build step reference #${BUILD_NUMBER}."
            echo "Review detailed workflow breakdown and execution outputs here: ${BUILD_URL}"
        }
        changed {
            echo "Build status changed to ${currentBuild.currentResult} - ${JOB_NAME} #${BUILD_NUMBER}"
        }
        always {
            echo "Wiping build environment and clean down complete."
            cleanWs()
        }
    }
}