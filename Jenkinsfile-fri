pipeline {
    agent {
        docker {
            image 'node:18-alpine'
            // Using host networking ensures the container can reach Nexus on 127.0.0.1 or localhost
            args  '--network=host -v /tmp:/tmp'
        }
    }

    environment {
        NODE_ENV         = 'test'
        BUILD_DIR        = 'dist'
        APP_NAME         = 'kijanikiosk-payments'
        NEXUS_URL        = 'http://127.0.0.1:8081/repository/npm-kijanikiosk/'
        
        // Explicitly dynamic environment variables evaluated safely via shell
        PKG_VERSION      = sh(script: "node -p \"require('./package.json').version\"", returnStdout: true).trim()
        GIT_SHORT        = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
        ARTIFACT_VERSION = "${PKG_VERSION}-b${BUILD_NUMBER}-${GIT_SHORT}"
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {
        stage('Lint') {
            steps {
                echo "Phase 1: Code Quality Check (Fail-Fast)"
                sh 'npm run lint'
            }
        }

        stage('Build') {
            steps {
                echo "Phase 2: Resolving Dependencies & Compiling Production Source"
                sh 'npm ci --prefer-offline --no-audit'
                sh 'npm run build'

                echo "Verifying build artifact presence..."
                sh '''
                    set -e
                    test -d "${BUILD_DIR}" || { echo "ERROR: ${BUILD_DIR} directory missing"; exit 1; }
                    test -n "$(ls -A ${BUILD_DIR})" || { echo "ERROR: ${BUILD_DIR} directory is empty"; exit 1; }
                '''

                echo "Stashing workspace outputs for subsequent downstream tasks..."
                // Challenge B Solution: Explicitly include package.json and lockfile alongside the compiled dist
                stash name: 'build-workspace', include: "${BUILD_DIR}/**, package.json, package-lock.json"
            }
        }

        stage('Verify') {
            parallel {
                stage('Test') {
                    steps {
                        echo "Running Isolated Test Runner Suite..."
                        unstash 'build-workspace'
                        sh '''
                            set -e
                            npm test -- --reporter=junit --reporter-options output=test-results/junit.xml
                        '''
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'test-results/*.xml'
                        }
                    }
                }
                
                stage('Security Audit') {
                    steps {
                        echo "Scanning Dependency Tree for High/Critical Vulnerabilities..."
                        unstash 'build-workspace'
                        sh 'npm audit --audit-level=high'
                    }
                }
            }
        }

        stage('Archive') {
            steps {
                echo "Persisting Fingerprinted Immutable Assets to Jenkins Master..."
                unstash 'build-workspace'
                archiveArtifacts artifacts: "${BUILD_DIR}/**",
                                 fingerprint: true,
                                 onlyIfSuccessful: true
            }
        }

        stage('Publish') {
            steps {
                unstash 'build-workspace'
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-credentials',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    sh '''
                        set -e

                        # Register the trap immediately before creating any files
                        trap "rm -f .npmrc" EXIT

                        # Generate Base64 credential token
                        NEXUS_TOKEN=$(echo -n "${NEXUS_USER}:${NEXUS_PASS}" | base64)

                        # Write out fresh configuration mapping (flush left to prevent workspace string space corruption)
cat > .npmrc << NPMRC
registry=http://127.0.0.1:8081/repository/npm-kijanikiosk/
//127.0.0.1:8081/repository/npm-kijanikiosk/:_authToken=${NEXUS_TOKEN}
NPMRC

                        # Update version schema to match the pipeline run definition
                        npm version "${ARTIFACT_VERSION}" --no-git-tag-version

                        # Push target payload to Nexus
                        npm publish
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "SUCCESS: Published ${APP_NAME} version ${ARTIFACT_VERSION} to Nexus Registry."
            echo "Artifact URL Location: ${NEXUS_URL}${APP_NAME}/-/${APP_NAME}-${ARTIFACT_VERSION}.tgz"
        }
        failure {
            echo "CRITICAL FAILURE: Pipeline execution failed at build item reference #${BUILD_NUMBER}."
            echo "Review console output maps directly at: ${BUILD_URL}"
        }
        changed {
            echo "Pipeline transition state modification tracked. Status is now: ${currentBuild.currentResult}"
        }
        always {
            echo "Purging temporary run environment files..."
            cleanWs()
        }
    }
}